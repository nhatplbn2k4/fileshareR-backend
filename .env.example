# PostgreSQL Database Configuration
POSTGRES_DB=document_management
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here

# Database Connection URL for Spring Boot
DATABASE_URL=jdbc:postgresql://localhost:5432/document_management
DATABASE_USERNAME=admin
DATABASE_PASSWORD=your_secure_password_here

# ── Payment Gateway ──────────────────────────────────────────────────────
# Setup docs: docs/PAYMENT-INTEGRATION.md
# VNPay sandbox: https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return

# MoMo sandbox: https://business.momo.vn
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8080/api/payments/momo/return
MOMO_IPN_URL=http://localhost:8080/api/payments/momo/ipn

# Frontend result page — SPA reads ?status=&txnRef=&error= from query
PAYMENT_FRONTEND_RETURN_URL=http://localhost:3000/payment/result
